NODE_ENV=development
PORT=4000

# MongoDB — local Mongo, or a connection string from MongoDB Atlas
MONGODB_URI=mongodb://localhost:27017/hrms

# Redis — local Redis, or a managed Redis URL
REDIS_URL=redis://localhost:6379

# JWT — generate with:  openssl rand -hex 64
JWT_SECRET=replace_me_with_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=replace_me_with_a_different_long_random_string_min_32
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# File uploads (payslips, attachments) — local disk path
UPLOAD_DIR=./uploads

# Meilisearch — optional (search feature)
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=masterKey

# SMTP — optional (password reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com

# Company branding (shown on payslips, invoices)
COMPANY_NAME=My Company
COMPANY_EMAIL=hr@example.com

# CORS — origin of the frontend (its public URL in production)
CORS_ORIGIN=http://localhost:5173

LOG_LEVEL=info
